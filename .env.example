# Django Settings
SECRET_KEY=your-secret-key-here-generate-a-strong-one
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=alba_erp
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@albacapital.com

# SMS Gateway (Africa's Talking or similar)
SMS_API_KEY=your-sms-api-key
SMS_USERNAME=your-sms-username
SMS_SENDER_ID=ALBACAPITAL

# Payment Integrations
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_SHORTCODE=your-paybill-number
MPESA_PASSKEY=your-mpesa-passkey
MPESA_ENVIRONMENT=sandbox  # or production

# Security
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True

# Application Settings
COMPANY_NAME=Alba Capital
COMPANY_EMAIL=info@albacapital.com
COMPANY_PHONE=+254700000000
BASE_CURRENCY=KES

# Logging
LOG_LEVEL=INFO
