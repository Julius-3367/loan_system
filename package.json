{
  "name": "alba-capital-erp",
  "version": "1.0.0",
  "description": "Alba Capital ERP System - Tailwind CSS Configuration",
  "scripts": {
    "dev": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css --watch",
    "build": "NODE_ENV=production tailwindcss -i ./static/css/input.css -o ./static/css/output.css --minify",
    "build:win": "set NODE_ENV=production && tailwindcss -i ./static/css/input.css -o ./static/css/output.css --minify"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "tailwindcss": "^3.4.1"
  }
}
